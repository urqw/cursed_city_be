if рнд=3  then goto Зомби1
if рнд=5  then goto Зомби2
if рнд=7  then goto Цэрбер
btn f4,Поўнач
Btn g5,Усход
Btn e5,Захад
End

:G5
pln Сектар: G-5
Pln Тут няма нічога, акрамя жылых будынкаў.
ад=1
да=11
proc rando
instr Loc=G5
if рнд=1  then goto Зомби0
if рнд=3  then goto Зомби1
if рнд=5  then goto Зомби2
if рнд=7  then goto Цэрбер
btn g4,Поўнач
Btn f5,Захад
End

:битва1
pln #/$
pln Хутчэй думай што рабіць:
pln Перад табой знаходзіцца #%монстар$.
if Жизньврага<1 then cls & pln Ты забіў ворага. & pause 2000 & goto #%Loc$
if Здароўе<0.1 then & pause 3000 & goto Смерць
btn страляць, Стрэліць у яго
btn збягаць, Паспрабаваць уцячы
btn уворот, Ухіліцца
end

:уворот
if Узброены_Пустэльным_арлом then inv- 50_А.Е_Патроны & патронпо=патронпо-1 
if Узброены_Рэмінгтонам then inv- М1100_Патроны & патронМ1=патронМ1-1
if Узброены_беретой then inv- 9мм_Патроны & патрон=патрон-1
ад=1
да=3
proc rando
if рнд=1 then Pln Табе не ўдалося ўхіліцца і #%монстар$ параніў цябе & pause 3000 & goto битва2
if рнд=2 then if патрон=0 then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_беретой & inv+ Берэтта & страты=0 
if патронпо=0 then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_Пустэльным_арлом & inv+ Пустэльны_арол & страты=0
if патронМ1=0 then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_Рэмінгтонам & inv+ Рэмінгтон & страты=0
if Узброены_Пустэльным_арлом then страты=50 & cls 
if Узброены_Рэмінгтонам then страты=20 & cls 
if Узброены_беретой then страты=10 & cls 
if frend=1 then pln (Страты сябра 10) & Жизньврага=Жизньврага-10
pln Табе ўдалося ўхіліцца і параніць #%монстар$
pln (У #%монстар$ было #Жизньврага$% здароўя) & pln ( -Твае страты: #страты$) & Жизньврага=Жизньврага-страты & pln (У #%монстар$ цяпер #Жизньврага$%здароўя) & pause 3000 & goto битва1
if рнд=3 then pln Табе ўдалося ўхіліцца і стрэліць у #%монстар$ але ты прамахнуўся & pause 3000 & goto битва1
end

:збягаць
pln Ты спрабуеш збегчы.
ад=1
да=5
proc rando
if himm=1 or nemm=1 or worm=1 then pln Ад яго не ўцячэш.& pause 1500 & goto битва2
if рнд>=4 then pln Табе удалося збегчы. & pause 3000 & goto #%Loc$
if рнд<4 then pln Табе не ўдалося збегчы. & pause 3000 & goto битва2

:битва2
cls
pln Атакуе #%монстар$:
pln #%монстар$ атакуе цябе. 
if Браня>0.1 then pln (У цябе было #Браня$% броні) & pln ( - Страты ворага: #уронврага$) & Браня=Браня-уронврага
if Браня<0.1 then pln (У цябе было #Здароўе$% здароўя) & pln ( - Страты ворага: #уронврага$) & Здароўе=Здароўе-уронврага
if Браня>0.1 then pln (У цябе цяпер #Браня$% броні)
if Здароўе>0. then pln (У цябе цяпер #Здароўе$% здароўя)
if Здароўе<0.1 then pln (Ты памёр)
goto битва1

:страляць
cls
if патрон=0 and not 9мм_Патроны then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_беретой & inv+ Берэтта & страты=0
if патронпо=0 and not 50_А.Е_Патроны then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_Пустэльным_арлом & inv+ Пустэльны_арол & страты=0
if патронМ1=0 and not М1100_Патроны then pln Скончыліся патроны і табе няма чым страляць & inv- Узброены_Рэмінгтонам & inv+ Рэмінгтон & страты=0
if Узброены_Пустэльным_арлом then inv- 50_А.Е_Патроны & патронпо=патронпо-1
if Узброены_Рэмінгтонам then inv- М1100_Патроны & патронМ1=патронМ1-1
if Узброены_беретой then inv- 9мм_Патроны & патрон=патрон-1
if Узброены_Пустэльным_арлом then страты=50 & cls 
if Узброены_Рэмінгтонам then страты=20 & cls 
if Узброены_беретой then страты=10 & cls 
if frend=1 then pln (Страты сябра 10) & Жизньврага=Жизньврага-10
if страты>0 then pln Ты целишся... І страляеш у #%монстар$.
pln (У #%монстар$ было #Жизньврага$% здароўя) & pln ( -Твае страты: #страты$) & Жизньврага=Жизньврага-страты
if Жизньврага>0 then pln (У #%монстар$ цяпер #Жизньврага$% здароўя)
if Жизньврага<0.1 then pln (#%монстар$ забіты )
pause 3000
goto битва2

:rando
proc rnd10
рнд=#rnd10$
end

:Зомби0
pln На цябе напаў зомбі
pln Ён марудными крокамі набліжаецца да цябе
image 15.jpg, 1, 1
Жизньврага=40
уронврага=10
instr монстар=Зомбі
worm=0
himm=0
worm=0
goto битва1

:Зомби1
pln На цябе напаў зомбі
pln Ён павольнымі крокамі набліжаецца да цябе
image 16.jpg, 1, 1
Жизньврага=40
уронврага=10
instr монстар=Зомбі
worm=0
himm=0
worm=0
goto битва1

:Зомби2
pln На цябе напаў зомбі
pln Ён павольнымі крокамі набліжаецца да цябе
image 17.jpg, 1, 1
Жизньврага=40
уронврага=10
instr монстар=Зомбі
worm=0
himm=0
worm=0
goto битва1

:ЗОМБИМ
pln На цябе напаў зомбі
pln Ён павольнымі крокамі набліжаецца да цябе
image 20.jpg, 1, 1
Жизньврага=40
уронврага=10
instr монстар=Зомбі
worm=0
himm=0
worm=0
goto битва1

:Цэрбер
pln На цябе напаў Цэрбер
pln Ён імчыцца да цябе.
image 18.jpg, 1, 1
Жизньврага=50
уронврага=20
instr монстар=Цэрбер
worm=0
himm=0
worm=0
goto битва1

:Немязіда
pln Ты напаў на Немязіду
pln Ты проста псіх!
image 21.jpg, 1, 1
Жизньврага=300
уронврага=50
instr монстар=Немязіда
nemm=1
goto битва1

:Хімера
pln На цябе напала хімера.
image 23.jpg, 1, 1
Жизньврага=300
уронврага=50
instr монстар=Хімера
himm=1
goto битва1

:Чарвяк
pln На цябе напаў велізарнага памеру чарвяк.
image 24.jpg, 1, 1
Жизньврага=300
уронврага=50
instr монстар=Чарвяк
worm=1
goto битва1

-------------------------------------------------------------------------------------------------------- 

:Смерць
cls 
Pln Ты па-геройску загінуў, ваюючы з монстрамі, якія апанавалі Ракун Сіці. 
invkill
perkill
btn Меню,Нанова?
End

:Смерть1
cls 
Pln Не паспеў ты прайсці і некалькіх метраў як цябе зжэрла расліна-мутант.
invkill
perkill
btn Меню,Нанова?
End

:Смерть2
Pln Наперадзе ўспыхнулі  два лазеры. Яны маланкава разрэзалі цябе на тры роўненькія кавалачкі.
invkill
perkill
btn Меню,Нанова?
End
